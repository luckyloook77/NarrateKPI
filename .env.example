# ─────────────────────────────────────────────────────────────────────
#  NarrateKPI — Environment Variables
# ─────────────────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your keys.
#  All variables are OPTIONAL — the app runs in dry-run / mock mode
#  when no API keys are configured.
# ─────────────────────────────────────────────────────────────────────

# ── LLM: NVIDIA (highest priority) ──────────────────────────────────
# Sign up: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-...
# Optional: model override (default: meta/llama-3.3-70b-instruct)
NVIDIA_MODEL_NAME=meta/llama-3.3-70b-instruct

# ── LLM: OpenAI (second priority) ──────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── LLM: DeepSeek (third priority) ─────────────────────────────────
# DEEPSEEK_API_KEY=sk-...

# ── LLM: Google Gemini (fourth priority) ────────────────────────────
# GEMINI_API_KEY=...

# ── Email: Resend ──────────────────────────────────────────────────
# Sign up: https://resend.com
RESEND_API_KEY=re_...
# Sender email (verified domain or onboarding@resend.dev for testing)
FROM_EMAIL=onboarding@resend.dev
# Legacy alias (used if FROM_EMAIL is not set):
# DEFAULT_FROM_EMAIL=reports@youragency.com

# ── Storage ─────────────────────────────────────────────────────────
# Path to the JSON store file (default: ./reports_store.json)
# NARRATEKPI_STORE_PATH=/opt/render/project/src/reports_store.json
