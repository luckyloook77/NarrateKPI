# ─────────────────────────────────────────────────────────────────────
#  NarrateKPI — Environment Variables
#  Copy this file to .env and fill in your keys.
#  The app runs in dry-run mode if no API keys are set.
# ─────────────────────────────────────────────────────────────────────

# ── LLM Provider (pick one) ─────────────────────────────────────────
# Used by llm_engine.py to generate narrative reports.
# When unset, the system outputs realistic pre-canned mock narratives.
#
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# DEEPSEEK_API_KEY=...

# ── Email Delivery (Resend) ─────────────────────────────────────────
# Used by email_service.py to dispatch reports via the Resend API.
# When unset, the system logs the email HTML locally instead of sending.
#
# RESEND_API_KEY=re_...
# DEFAULT_FROM_EMAIL=reports@youragency.com

# ── File Paths (optional) ───────────────────────────────────────────
# Override the default JSON store location.
# Default: reports_store.json (in the application root).
#
# NARRATEKPI_STORE_PATH=/data/reports_store.json
